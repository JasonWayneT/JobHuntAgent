# ============================================================
# IMPORTANT: You do NOT need to edit this file to use the app.
# All API keys should be configured via the Settings panel in
# the UI (Settings > API or Connections). Keys are stored in
# the local SQLite database and injected at runtime.
#
# This file is an OPTIONAL fallback for local development only.
# It is excluded from git and will never be committed.
# ============================================================

# Fallback: Perplexity API (preferred: set via UI Settings > Data Sources)
PERPLEXITY_API_KEY=

# Fallback: Gemini API (preferred: set via UI Settings > API or Connections)
GEMINI_API_KEY=

# Fallback: Anthropic/Claude API (preferred: set via UI Settings > API or Connections)
ANTHROPIC_API_KEY=

# Fallback: Adzuna job aggregator (preferred: set via UI Settings > Data Sources)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
